# --- 13. Quick Menu ---
# Shows a neat list of all the functions you made
function lf {
    $funcs = @(Get-Command -Type Function | Where-Object { $_.Name -notin @("lf", "Test-Cmd", "prompt") } | Select-Object -ExpandProperty Name)
    Write-Host "╔════════════════════════════════════════════════════╗" -ForegroundColor Cyan
    Write-Host "║                CUSTOM FUNCTIONS                    ║" -ForegroundColor Cyan
    Write-Host "╠════════════════════════════════════════════════════╣" -ForegroundColor Cyan
    foreach ($name in $funcs) {
        Write-Host ("║  {0,-48}  ║" -f $name) -ForegroundColor Cyan
    }
    Write-Host "╚════════════════════════════════════════════════════╝" -ForegroundColor Cyan
}

